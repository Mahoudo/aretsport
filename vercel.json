{
  "version": 2,
  "builds": [
    { "src": "api/matches.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/matches", "dest": "/api/matches.js" },
    { "src": "/health", "dest": "/api/matches.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache, no-store" }
      ]
    }
  ]
}
